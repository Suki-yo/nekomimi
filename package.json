{
  "name": "nekomimi",
  "productName": "Nekomimi",
  "version": "1.0.0",
  "description": "The anime game launcher",
  "license": "MIT",
  "author": "Jeffrey Qin",
  "type": "commonjs",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run dev:renderer & npm run dev:main",
    "dev:main": "tsc && electron .",
    "dev:renderer": "vite",
    "build": "tsc && vite build",
    "dist:linux": "npm run build && electron-builder --linux AppImage",
    "postinstall": "electron-builder install-app-deps",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.0",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "claude": "^0.1.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0",
    "protobufjs": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^3.4.1",
    "yaml": "^2.6.0",
    "zstd-codec": "^0.1.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.jeffreyqin.nekomimi",
    "productName": "Nekomimi",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      "resources/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  }
}
